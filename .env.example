# Nostradamus IoT Observatory SDK - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# Project Configuration
NOSTRADAMUS_PROJECT_ID=your-project-uuid-here

# API Keys
# Master Key - Full access (create/read/write/delete)
NOSTRADAMUS_MASTER_KEY=your-master-api-key-here

# Write Key - Write and read access
NOSTRADAMUS_WRITE_KEY=your-write-api-key-here

# Read Key - Read-only access
NOSTRADAMUS_READ_KEY=your-read-api-key-here

# Optional: OAuth2 Credentials (alternative to API keys)
# NOSTRADAMUS_USERNAME=your-username
# NOSTRADAMUS_PASSWORD=your-password

# Optional: Custom API Base URL (defaults to production)
# NOSTRADAMUS_BASE_URL=https://nostradamus-ioto.issel.ee.auth.gr/api/v1
